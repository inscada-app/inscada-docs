---
interface Props {
	activeVersion: string;
}

const { activeVersion } = Astro.props;

const otherVersion = activeVersion === 'jdk11' ? 'jdk21' : 'jdk11';

const currentPath = Astro.url.pathname;
const otherPath = currentPath.includes(`/${activeVersion}/`)
	? currentPath.replace(`/${activeVersion}/`, `/${otherVersion}/`)
	: currentPath.replace(`/${activeVersion}`, `/${otherVersion}`);

const versions = [
	{ id: 'jdk11', label: 'JDK 11', hint: 'Legacy' },
	{ id: 'jdk21', label: 'JDK 21', hint: 'Current' },
];
---

<div class="version-switcher" data-active={activeVersion}>
	{versions.map((v) => {
		const isActive = v.id === activeVersion;
		const href = isActive ? currentPath : otherPath;
		return (
			<a
				href={href}
				class:list={['version-pill', { active: isActive }]}
				data-version={v.id}
				aria-current={isActive ? 'page' : undefined}
			>
				<span class="label">{v.label}</span>
				<span class="hint">{v.hint}</span>
			</a>
		);
	})}
</div>

<script>
	const active = document.querySelector('.version-switcher')?.getAttribute('data-active');
	if (active) {
		try { localStorage.setItem('inscadaDocsVersion', active); } catch {}
	}
</script>

<style>
	.version-switcher {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.25rem;
		padding: 0.5rem 0;
		margin-bottom: 0.5rem;
		border-bottom: 1px solid var(--sl-color-hairline);
	}
	.version-pill {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.1rem;
		padding: 0.4rem 0.5rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.4rem;
		text-decoration: none;
		color: var(--sl-color-gray-2);
		font-size: 0.8rem;
		line-height: 1;
		transition: background 0.15s, border-color 0.15s, color 0.15s;
	}
	.version-pill:hover {
		background: var(--sl-color-gray-6);
		color: var(--sl-color-white);
	}
	.version-pill.active {
		background: var(--sl-color-accent-low);
		border-color: var(--sl-color-accent);
		color: var(--sl-color-accent-high);
	}
	.version-pill .label {
		font-weight: 700;
	}
	.version-pill .hint {
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		opacity: 0.7;
	}
</style>
